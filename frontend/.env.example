# Set to "true" for demo: after login you are redirected to Upload Tensor and can use agent-only areas.
# Use this to design and preview the upload interface without real auth.
NEXT_PUBLIC_DEMO_ACCESS=true

# Backend API base URL (no trailing slash). Used on /onboard for copy-paste examples.
# Local dev: http://localhost:8080
# Production: https://your-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080
