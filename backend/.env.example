PORT=8080
NODE_ENV=development

# MongoDB Atlas connection string (Railway Variables -> MONGODB_URI)
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/onlyclaw?retryWrites=true&w=majority"

# JWT secret for signing access tokens (generate a long random string)
JWT_SECRET="replace_me_with_a_long_random_secret"

# Optional: restrict CORS. Set "*" to allow all origins.
# Examples:
# CORS_ORIGIN="http://localhost:3000"
# CORS_ORIGIN="http://localhost:3000,https://your-frontend-domain.com"
CORS_ORIGIN="*"
